#!/usr/bin/env python3
import paho.mqtt.client as mqtt
import json
import sqlite3
import os
import threading
import time
import logging
from logging.handlers import RotatingFileHandler

# ============================================================
# CONFIGURATION
# ============================================================

MQTT_HOST = "localhost"
MQTT_PORT = 1883
MQTT_TOPIC_DETECT = "parking/beacon/detected"
MQTT_TOPIC_OPEN = "parking/relay/command"

DB_PATH = os.path.expanduser("~/portail/data/users.db")
DISPLAY_FILE = "/tmp/current_display.json"
LOG_FILE = "/home/administrateur/portail/logs/portail.log"

DISPLAY_DURATION = 60

# Absence / retour par balise
ABSENT_THRESHOLD = -80
VERY_WEAK_THRESHOLD = -95
ABSENT_REQUIRED = 10

# Anti-boucle
WORKER_OPEN_COOLDOWN = 10   # pour la même balise
GLOBAL_OPEN_COOLDOWN = 2   # toutes balises confondues

# Exception métier
AMIRA_MINOR = 10129

os.makedirs(os.path.dirname(LOG_FILE), exist_ok=True)

# ============================================================
# LOGGING
# ============================================================

def setup_logging():
    logger = logging.getLogger("portail")
    logger.setLevel(logging.DEBUG)

    if logger.handlers:
        return logger

    formatter = logging.Formatter("%(asctime)s - %(levelname)s - %(message)s")

    file_handler = RotatingFileHandler(LOG_FILE, maxBytes=1024 * 1024, backupCount=5)
    file_handler.setFormatter(formatter)
    logger.addHandler(file_handler)

    console_handler = logging.StreamHandler()
    console_handler.setFormatter(formatter)
    logger.addHandler(console_handler)

    return logger


log = setup_logging()

# ============================================================
# ÉTAT GLOBAL
# ============================================================

current_timer = None
timer_lock = threading.Lock()

# Compteur absence par balise
absent_count = {}

# Balises actuellement considérées présentes
present_beacons = set()

# Dernière ouverture par balise
last_open_times = {}

# Dernière ouverture globale
last_global_open_time = 0

# ============================================================
# OUTILS
# ============================================================

def make_key(uuid, major, minor):
    return f"{uuid}|{major}|{minor}"


# ============================================================
# MQTT / PORTAIL
# ============================================================

def open_gate(beacon_key, name):
    global last_global_open_time

    now = time.time()

    # Anti-boucle global
    if now - last_global_open_time < GLOBAL_OPEN_COOLDOWN:
        remaining = GLOBAL_OPEN_COOLDOWN - (now - last_global_open_time)
        log.info(f"⏱️ Anti-boucle GLOBAL : ouverture refusée pour {name} ({remaining:.1f}s restantes)")
        return False

    # Anti-boucle par balise
    last_time = last_open_times.get(beacon_key, 0)
    if now - last_time < WORKER_OPEN_COOLDOWN:
        remaining = WORKER_OPEN_COOLDOWN - (now - last_time)
        log.info(f"⏱️ Anti-boucle worker pour {name} : ouverture refusée ({remaining:.1f}s restantes)")
        return False

    log.info(f"🔊 Tentative d'ouverture pour {name}")

    try:
        client = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2)
        client.connect(MQTT_HOST, MQTT_PORT, 5)
        client.loop_start()

        result = client.publish(MQTT_TOPIC_OPEN, "OPEN")
        result.wait_for_publish()

        client.loop_stop()
        client.disconnect()

        if result.rc == mqtt.MQTT_ERR_SUCCESS:
            last_open_times[beacon_key] = now
            last_global_open_time = now
            log.info(f"🔓 OUVERTURE PORTAIL pour {name}")
            return True

        log.warning(f"⚠️ Échec envoi MQTT (code {result.rc}) pour {name}")
        return False

    except Exception as e:
        log.error(f"❌ Erreur dans open_gate pour {name}: {e}")
        return False


def on_connect(client, userdata, flags, rc, properties=None):
    if rc == 0:
        log.info(f"✅ Connecté à MQTT (code {rc})")
        client.subscribe(MQTT_TOPIC_DETECT)
        log.info(f"   Souscrit au topic: {MQTT_TOPIC_DETECT}")
    else:
        log.error(f"❌ Échec connexion MQTT (code {rc})")


# ============================================================
# AFFICHAGE
# ============================================================

def cancel_current_timer():
    global current_timer
    with timer_lock:
        if current_timer and current_timer.is_alive():
            current_timer.cancel()
            log.debug("🕒 Ancien timer d'affichage annulé")
            current_timer = None


def clear_display():
    global current_timer
    try:
        if os.path.exists(DISPLAY_FILE):
            os.remove(DISPLAY_FILE)
        log.info("🕒 Timer expiré - Affichage effacé")
    except Exception as e:
        log.error(f"❌ Erreur effacement affichage: {e}")
    finally:
        with timer_lock:
            current_timer = None


def schedule_clear():
    global current_timer
    with timer_lock:
        current_timer = threading.Timer(DISPLAY_DURATION, clear_display)
        current_timer.daemon = True
        current_timer.start()
        log.debug(f"🕒 Nouveau timer d'affichage ({DISPLAY_DURATION}s)")


def update_display(name):
    try:
        data = {
            "name": name,
            "timestamp": time.time()
        }
        with open(DISPLAY_FILE, "w") as f:
            json.dump(data, f)
        log.info(f"📺 Affichage mis à jour: {name}")
    except Exception as e:
        log.error(f"❌ Erreur mise à jour affichage: {e}")


# ============================================================
# BASE DE DONNÉES
# ============================================================

def init_db():
    try:
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()

        c.execute("""
            CREATE TABLE IF NOT EXISTS users (
                minor INTEGER PRIMARY KEY,
                name TEXT NOT NULL,
                email TEXT,
                active BOOLEAN DEFAULT 1,
                rssi_threshold INTEGER DEFAULT -70,
                uuid TEXT,
                major INTEGER
            )
        """)

        c.execute("""
            CREATE UNIQUE INDEX IF NOT EXISTS idx_beacon
            ON users(uuid, major, minor)
        """)

        users = [
            (26049, "Jean Dupont", "jean@roole.fr", 1, -70, "fda50693-a4e2-4fb1-afcf-c6eb07647825", 10065),
            (10129, "Amira Bouhdiba", "amira@roole.fr", 1, -70, "9730c8c0-24fe-327a-3f63-623c87e24797", 20001),
            (20055, "Pierre Durand", "pierre@roole.fr", 1, -70, "fda50693-a4e2-4fb1-afcf-c6eb07647825", 10065),
        ]

        for user in users:
            c.execute("""
                INSERT OR IGNORE INTO users
                (minor, name, email, active, rssi_threshold, uuid, major)
                VALUES (?, ?, ?, ?, ?, ?, ?)
            """, user)

        conn.commit()
        conn.close()
        log.info("✅ Base de données initialisée")
    except Exception as e:
        log.error(f"❌ Erreur initialisation BDD: {e}")


def get_user_from_beacon(uuid, major, minor):
    try:
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute("""
            SELECT name, email, rssi_threshold, active
            FROM users
            WHERE uuid = ? AND major = ? AND minor = ?
        """, (uuid, major, minor))
        result = c.fetchone()
        conn.close()
        return result
    except Exception as e:
        log.error(f"❌ Erreur lecture BDD: {e}")
        return None


# ============================================================
# PRÉSENCE / ABSENCE PAR BALISE
# ============================================================

def mark_absent(beacon_key, name, reason):
    was_present = beacon_key in present_beacons
    present_beacons.discard(beacon_key)
    if was_present:
        log.info(f"🚗 {name} considéré absent ({reason})")
    else:
        log.info(f"🚗 {name} absent confirmé ({reason})")


def handle_presence_state(beacon_key, name, rssi, threshold):
    """
    Retourne un tuple:
    - eligible_now: True si la balise est assez proche pour ouvrir maintenant
    - returned_now: True si la balise revient après absence
    """
    previously_present = beacon_key in present_beacons

    # Absence immédiate
    if rssi < VERY_WEAK_THRESHOLD:
        absent_count[beacon_key] = ABSENT_REQUIRED
        mark_absent(beacon_key, name, f"signal extrêmement faible {rssi}")
        return False, False

    # Absence progressive
    if rssi < ABSENT_THRESHOLD:
        absent_count[beacon_key] = absent_count.get(beacon_key, 0) + 1
        log.info(
            f"📉 Signal faible ({rssi}) pour {name}, "
            f"compteur absence: {absent_count[beacon_key]}/{ABSENT_REQUIRED}"
        )
        if absent_count[beacon_key] >= ABSENT_REQUIRED:
            mark_absent(beacon_key, name, f"{ABSENT_REQUIRED} détections faibles")
        return False, False

    # Signal revenu "normal" vis-à-vis de l'absence
    if absent_count.get(beacon_key, 0) > 0:
        log.info(f"📈 Signal redevenu normal pour {name}, compteur absence remis à 0")
    absent_count[beacon_key] = 0

    # Pas assez proche pour ouvrir => ne pas considérer comme présent actif
    if rssi <= threshold:
        if beacon_key in present_beacons:
            present_beacons.discard(beacon_key)
            log.info(f"🚪 {name} retiré de l'état présent actif (RSSI {rssi} ≤ seuil {threshold})")
        log.info(f"📶 RSSI {rssi} ≤ seuil utilisateur {threshold} pour {name} → pas d'ouverture")
        return False, False

    # Ici la balise est assez proche pour ouvrir
    if not previously_present:
        present_beacons.add(beacon_key)
        log.info(f"🔄 {name} est de retour / nouvellement présent")
        return True, True

    return True, False


# ============================================================
# LOGIQUE MÉTIER
# ============================================================

def on_message(client, userdata, msg):
    try:
        payload = json.loads(msg.payload.decode())

        uuid = payload.get("uuid")
        major = payload.get("major")
        minor = payload.get("minor")
        rssi = payload.get("rssi")

        log.info(f"📩 Message reçu - UUID: {uuid}, Major: {major}, Minor: {minor}, RSSI: {rssi}")

        if uuid is None or major is None or minor is None or rssi is None:
            log.warning("⚠️ Payload incomplet, message ignoré")
            return

        beacon_key = make_key(uuid, major, minor)

        # Vérifier l'utilisateur
        user = get_user_from_beacon(uuid, major, minor)
        if not user:
            log.warning(f"⚠️ Balise {beacon_key} non autorisée")
            return

        name, email, threshold, active = user

        if not active:
            log.info(f"⏸️ Utilisateur {name} désactivé")
            return

        log.info(f"✅ Utilisateur identifié: {name} (seuil: {threshold})")

        # Affichage
        cancel_current_timer()
        update_display(name)
        schedule_clear()

        eligible_now, returned_now = handle_presence_state(beacon_key, name, rssi, threshold)

        if not eligible_now:
            return

        # Cas standard + Amira :
        # ouverture seulement si cette balise vient réellement de revenir
        if returned_now:
            if minor == AMIRA_MINOR:
                log.info("⭐ Amira revient - OUVERTURE")
            else:
                log.info(f"👤 {name} revient - OUVERTURE")

            open_gate(beacon_key, name)
            return

        # Balise toujours présente
        if minor == AMIRA_MINOR:
            log.info("⭐ Amira déjà présente - PAS D'OUVERTURE")
        else:
            log.info(f"👤 {name} déjà présent - PAS D'OUVERTURE")

    except Exception as e:
        log.error(f"❌ Erreur traitement message: {e}", exc_info=True)


# ============================================================
# MAIN
# ============================================================

if __name__ == "__main__":
    log.info("=" * 60)
    log.info("🚀 PORTAIL WORKER - MODE RETOUR INDIVIDUEL")
    log.info("=" * 60)
    log.info(f"📺 Durée affichage: {DISPLAY_DURATION}s")
    log.info(f"📉 Seuil absence progressive: {ABSENT_THRESHOLD} dBm")
    log.info(f"🚨 Seuil absence immédiate: {VERY_WEAK_THRESHOLD} dBm")
    log.info(f"🔁 Détections faibles nécessaires pour absence: {ABSENT_REQUIRED}")
    log.info(f"⏱️ Cooldown worker ouverture: {WORKER_OPEN_COOLDOWN}s")
    log.info(f"⏱️ Cooldown global ouverture: {GLOBAL_OPEN_COOLDOWN}s")
    log.info(f"⭐ Exception Amira (minor {AMIRA_MINOR})")
    log.info(f"📁 Logs: {LOG_FILE}")

    init_db()

    try:
        if os.path.exists(DISPLAY_FILE):
            os.remove(DISPLAY_FILE)
            log.info("🧹 Ancien fichier d'affichage nettoyé")
    except Exception:
        pass

    client = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2)
    client.on_connect = on_connect
    client.on_message = on_message

    try:
        client.connect(MQTT_HOST, MQTT_PORT, 60)
        log.info("✅ En attente des messages...")
        client.loop_forever()
    except Exception as e:
        log.error(f"❌ Erreur fatale: {e}")
