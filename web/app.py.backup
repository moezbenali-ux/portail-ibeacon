#!/usr/bin/env python3
from flask import Flask, render_template_string, jsonify
import json
import os
import time

app = Flask(__name__)

DISPLAY_FILE = "/tmp/current_display.json"

HTML = """
<!DOCTYPE html>
<html>
<head>
    <title>Portail Parking</title>
    <style>
        body { 
            margin: 0; 
            padding: 0; 
            background: #000; 
            color: #fff; 
            font-family: 'Arial Black', sans-serif; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            overflow: hidden;
        }
        #message { 
            font-size: 10vw; 
            text-align: center; 
            animation: fade 1s;
        }
        @keyframes fade {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        .timestamp {
            position: absolute;
            bottom: 20px;
            right: 20px;
            font-size: 1vw;
            color: #666;
        }
    </style>
    <script>
        function updateDisplay() {
            fetch('/current')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('message').innerText = data.message;
                    if (data.timestamp) {
                        let date = new Date(data.timestamp * 1000);
                        document.getElementById('timestamp').innerText = date.toLocaleTimeString();
                    }
                });
        }
        setInterval(updateDisplay, 1000);
        window.onload = updateDisplay;
    </script>
</head>
<body>
    <div id="message">En attente...</div>
    <div id="timestamp" class="timestamp"></div>
</body>
</html>
"""

@app.route('/')
def index():
    return HTML

@app.route('/current')
def current():
    try:
        if os.path.exists(DISPLAY_FILE):
            with open(DISPLAY_FILE, 'r') as f:
                data = json.load(f)
            
            # Vérifier que le message n'est pas trop vieux
            if time.time() - data.get('timestamp', 0) < 60:  # 60 secondes
                return jsonify({
                    "message": f"Bienvenue {data['name']}",
                    "timestamp": data['timestamp']
                })
    except:
        pass
    
    return jsonify({"message": "En attente..."})

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
